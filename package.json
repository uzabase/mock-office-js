{
  "name": "mock-office-js",
  "version": "0.0.2",
  "description": "In-memory mock of Office JavaScript API for testing Office Add-ins",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/office.js",
      "default": "./dist/office.esm.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:typecheck": "vitest --typecheck --run",
    "playwright:install": "playwright install chromium",
    "pretest:e2e": "npm run build && cd tests/e2e/fixture && npm install",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts"
  },
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/custom-functions-runtime": "^1.6.11",
    "@types/office-js": "^1.0.587",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
