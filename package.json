{
  "name": "mock-office-js",
  "version": "0.0.2",
  "description": "In-memory mock of Office JavaScript API for testing Office Add-ins",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:typecheck": "vitest --typecheck --run"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/custom-functions-runtime": "^1.6.11",
    "@types/office-js": "^1.0.587",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
